                    </div>
                </div>
            </div>

            <!-- 濒危评估 -->
            <div class="section">
                <h2>⚠️ 能力系统崩溃指数</h2>
                <table style="width:100%; border-collapse: collapse;">
                    <thead>
                        <tr style="background:#667eea; color:white;">
